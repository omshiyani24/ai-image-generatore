        <div class="glass mx-auto max-w-5xl rounded-3xl p-2.5 shadow-2xl shadow-indigo-950/40 sm:p-3">
          <div class="flex items-end gap-2">
            <div class="min-w-0 flex-1">
              <label for="promptInput" class="sr-only">Image prompt</label>
              <textarea
                id="promptInput"
                rows="1"
                placeholder="Describe the image you want to create..."
                class="max-h-32 min-h-[52px] w-full resize-none bg-transparent px-3 py-3 text-sm leading-6 text-white outline-none placeholder:text-slate-600 sm:px-4"
              ></textarea>
            </div>

            <button id="enhanceButton" title="Magic Enhance" class="grid h-[52px] w-[52px] shrink-0 place-items-center rounded-2xl border border-fuchsia-400/15 bg-fuchsia-500/10 text-xl text-fuchsia-300 transition hover:-translate-y-0.5 hover:bg-fuchsia-500/20">
              <i class="ph-fill ph-magic-wand"></i>
            </button>

            <button id="generateButton" class="button-shine inline-flex h-[52px] shrink-0 items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-indigo-500 to-fuchsia-500 px-5 text-sm font-extrabold text-white shadow-glow transition hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-50 sm:px-7">
              <i class="ph-fill ph-sparkle"></i>
              <span class="hidden sm:inline">Generate</span>
            </button>
          </div>

          <div class="hidden items-center justify-between border-t border-white/5 px-4 pt-2 text-[10px] text-slate-600 sm:flex">
            <span>Press <kbd class="rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-slate-400">Ctrl + Enter</kbd> to generate</span>
            <span id="promptCounter">0 / 1000</span>
          </div>
        </div>
      </div>
    </main>
  </section>

  <!-- Toast container -->
  <div id="toastContainer" class="fixed bottom-5 right-5 z-[200] flex w-[min(360px,calc(100%-2rem))] flex-col gap-3"></div>

  <script>
    (() => {
      "use strict";

      // ---------- DOM ----------
      const landingPage = document.getElementById("landingPage");
      const appInterface = document.getElementById("appInterface");
      const openAppButtons = document.querySelectorAll(".open-app");
      const backHomeButton = document.getElementById("backHomeButton");
      const mobileMenuButton = document.getElementById("mobileMenuButton");
      const mobileMenu = document.getElementById("mobileMenu");

      const appSidebar = document.getElementById("appSidebar");
      const sidebarOverlay = document.getElementById("sidebarOverlay");
      const mobileSidebarButton = document.getElementById("mobileSidebarButton");
      const closeSidebarButton = document.getElementById("closeSidebarButton");

      const ratioButtons = document.querySelectorAll(".ratio-btn");
      const ratioLabel = document.getElementById("ratioLabel");
      const canvasFrame = document.getElementById("canvasFrame");
      const styleSelect = document.getElementById("styleSelect");
      const seedInput = document.getElementById("seedInput");
      const randomSeedButton = document.getElementById("randomSeedButton");
      const modelSelect = document.getElementById("modelSelect");
      const negativePrompt = document.getElementById("negativePrompt");

      const advancedToggle = document.getElementById("advancedToggle");
      const advancedPanel = document.getElementById("advancedPanel");
      const advancedCaret = document.getElementById("advancedCaret");

      const placeholderState = document.getElementById("placeholderState");
      const loadingState = document.getElementById("loadingState");
      const resultImage = document.getElementById("resultImage");
      const resultActions = document.getElementById("resultActions");
      const resultBadge = document.getElementById("resultBadge");

      const promptInput = document.getElementById("promptInput");
      const promptCounter = document.getElementById("promptCounter");
      const enhanceButton = document.getElementById("enhanceButton");
      const generateButton = document.getElementById("generateButton");
      const downloadButton = document.getElementById("downloadButton");
      const shareButton = document.getElementById("shareButton");
      const clearCanvasButton = document.getElementById("clearCanvasButton");

      const historyGrid = document.getElementById("historyGrid");
      const emptyHistory = document.getElementById("emptyHistory");
      const clearHistoryButton = document.getElementById("clearHistoryButton");
      const toastContainer = document.getElementById("toastContainer");

      // ---------- State ----------
      const HISTORY_KEY = "prismai_generation_history_v1";
      const ratioMap = {
        square: { width: 1024, height: 1024, label: "1:1", className: "aspect-square" },
        wide: { width: 1280, height: 720, label: "16:9", className: "aspect-video" },
        portrait: { width: 768, height: 1152, label: "2:3", className: "aspect-[2/3]" }
      };

      let state = {
        ratio: "square",
        currentImageUrl: "",
        currentPrompt: "",
        currentHistoryId: null,
        isLoading: false,
        history: loadHistory()
      };

      // ---------- Helpers ----------
      function showToast(message, type = "info") {
        const iconMap = {
          success: "ph-check-circle",
          error: "ph-warning-circle",
          info: "ph-info"
        };
        const colorMap = {
          success: "text-emerald-300 border-emerald-400/20",
          error: "text-rose-300 border-rose-400/20",
          info: "text-indigo-300 border-indigo-400/20"
        };

        const toast = document.createElement("div");
        toast.className = `toast glass flex items-start gap-3 rounded-2xl border p-4 shadow-2xl ${colorMap[type]}`;
        toast.innerHTML = `
          <i class="ph-fill ${iconMap[type]} mt-0.5 text-lg"></i>
          <p class="flex-1 text-sm leading-6 text-slate-200">${escapeHTML(message)}</p>
          <button class="text-slate-500 hover:text-white" aria-label="Close notification"><i class="ph ph-x"></i></button>
        `;
        toast.querySelector("button").addEventListener("click", () => toast.remove());
        toastContainer.appendChild(toast);

        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateY(8px)";
          setTimeout(() => toast.remove(), 250);
        }, 3500);
      }

      function escapeHTML(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function loadHistory() {
        try {
          const parsed = JSON.parse(localStorage.getItem(HISTORY_KEY) || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }

      function saveHistory() {
        try {
          localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history.slice(0, 24)));
        } catch (error) {
          console.warn("Could not save history:", error);
          showToast("Browser storage is unavailable. History was not saved.", "error");
        }
      }

      function randomSeed() {
        return Math.floor(Math.random() * 999999999);
      }

      function resizePromptInput() {
        promptInput.style.height = "auto";
        promptInput.style.height = `${Math.min(promptInput.scrollHeight, 128)}px`;
        promptCounter.textContent = `${promptInput.value.length} / 1000`;
      }

      function setLoading(loading) {
        state.isLoading = loading;
        generateButton.disabled = loading;
        enhanceButton.disabled = loading;

        if (loading) {
          placeholderState.classList.add("hidden");
          resultImage.classList.add("hidden");
          resultActions.classList.add("hidden");
          resultActions.classList.remove("flex");
          resultBadge.classList.add("hidden");
          loadingState.classList.remove("hidden");
          generateButton.innerHTML = '<i class="ph ph-spinner animate-spin"></i><span class="hidden sm:inline">Generating</span>';
        } else {
          loadingState.classList.add("hidden");
          generateButton.innerHTML = '<i class="ph-fill ph-sparkle"></i><span class="hidden sm:inline">Generate</span>';
        }
      }

      function resetCanvas() {
        state.currentImageUrl = "";
        state.currentPrompt = "";
        state.currentHistoryId = null;
        resultImage.removeAttribute("src");
        resultImage.classList.add("hidden");
        resultActions.classList.add("hidden");
        resultActions.classList.remove("flex");
        resultBadge.classList.add("hidden");
        loadingState.classList.add("hidden");
        placeholderState.classList.remove("hidden");
        document.querySelectorAll(".history-item").forEach(item => item.classList.remove("active"));
      }

      // ---------- Landing / App transition ----------
      function openApp() {
        landingPage.classList.add("hidden");
        appInterface.classList.remove("hidden");
        appInterface.classList.add("app-fade-in");
        document.body.style.overflow = "hidden";
        mobileMenu.classList.add("hidden");
        setTimeout(() => promptInput.focus(), 250);
      }

      function closeApp() {
        closeMobileSidebar();
        appInterface.classList.add("hidden");
        appInterface.classList.remove("app-fade-in");
        landingPage.classList.remove("hidden");
        document.body.style.overflow = "";
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      openAppButtons.forEach(button => button.addEventListener("click", openApp));
      backHomeButton.addEventListener("click", closeApp);
      mobileMenuButton.addEventListener("click", () => mobileMenu.classList.toggle("hidden"));

      // ---------- Mobile sidebar ----------
      function openMobileSidebar() {
        appSidebar.classList.remove("-translate-x-full");
        sidebarOverlay.classList.remove("hidden");
      }

      function closeMobileSidebar() {
        if (window.innerWidth < 768) {
          appSidebar.classList.add("-translate-x-full");
          sidebarOverlay.classList.add("hidden");
        }
      }

      mobileSidebarButton.addEventListener("click", openMobileSidebar);
      closeSidebarButton.addEventListener("click", closeMobileSidebar);
      sidebarOverlay.addEventListener("click", closeMobileSidebar);

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 768) {
          appSidebar.classList.remove("-translate-x-full");
          sidebarOverlay.classList.add("hidden");
        } else if (sidebarOverlay.classList.contains("hidden")) {
          appSidebar.classList.add("-translate-x-full");
        }
      });

      // ---------- Ratio ----------
      function setRatio(ratio) {
        if (!ratioMap[ratio]) return;
        state.ratio = ratio;
        ratioLabel.textContent = ratioMap[ratio].label;

        Object.values(ratioMap).forEach(config => canvasFrame.classList.remove(config.className));
        canvasFrame.classList.add(ratioMap[ratio].className);

        ratioButtons.forEach(button => {
          button.classList.toggle("active", button.dataset.ratio === ratio);
        });
      }

      ratioButtons.forEach(button => {
        button.addEventListener("click", () => setRatio(button.dataset.ratio));
      });

      // ---------- Advanced ----------
      advancedToggle.addEventListener("click", () => {
        advancedPanel.classList.toggle("hidden");
        advancedCaret.classList.toggle("rotate-180");
      });

      randomSeedButton.addEventListener("click", () => {
        seedInput.value = randomSeed();
        showToast("A new random seed was selected.", "info");
      });

      // ---------- Prompt ----------
      promptInput.addEventListener("input", () => {
        if (promptInput.value.length > 1000) {
          promptInput.value = promptInput.value.slice(0, 1000);
        }
        resizePromptInput();
      });

      promptInput.addEventListener("keydown", event => {
        if ((event.ctrlKey || event.metaKey) && event.key === "Enter") {
          event.preventDefault();
          generateImage();
        }
      });

      document.querySelectorAll(".prompt-chip").forEach(chip => {
        chip.addEventListener("click", () => {
          const examples = {
            "Futuristic city": "A futuristic neon city floating above the clouds at night, flying vehicles, cinematic wide shot",
            "Fantasy castle": "A majestic fantasy castle on a mountain, waterfalls, dramatic sunrise, magical atmosphere",
            "Product photo": "Luxury smartwatch product photography on a reflective black surface, studio lighting, premium advertisement"
          };
          promptInput.value = examples[chip.textContent.trim()] || chip.textContent.trim();
          resizePromptInput();
          promptInput.focus();
        });
      });

      enhanceButton.addEventListener("click", () => {
        const value = promptInput.value.trim();
        if (!value) {
          showToast("Write a basic prompt first, then use Magic Enhance.", "error");
          promptInput.focus();
          return;
        }

        const enhancement = "ultra detailed, masterpiece, 8k resolution, professional composition, cinematic lighting, sharp focus, rich textures";
        if (!value.toLowerCase().includes("masterpiece")) {
          promptInput.value = `${value}, ${enhancement}`;
          resizePromptInput();
          showToast("Professional visual keywords were added.", "success");
        } else {
          showToast("This prompt already looks enhanced.", "info");
        }
      });

      // ---------- API generation ----------
      function buildImageUrl(prompt, width, height, seed, model, negative) {
        const style = styleSelect.value;
        let finalPrompt = `${prompt}, ${style} style`;

        if (negative.trim()) {
          finalPrompt += `. Avoid: ${negative.trim()}`;
        }

        return `https://image.pollinations.ai/prompt/${encodeURIComponent(finalPrompt)}?width=${width}&height=${height}&seed=${seed}&model=${encodeURIComponent(model)}&nologo=true`;
      }

      async function generateImage() {
        if (state.isLoading) return;

        const prompt = promptInput.value.trim();
        if (!prompt) {
          showToast("Please enter a prompt before generating.", "error");
          promptInput.focus();
          return;
        }

        const ratio = ratioMap[state.ratio];
        const seed = seedInput.value.trim() === "" ? randomSeed() : Math.abs(parseInt(seedInput.value, 10) || randomSeed());
        const model = modelSelect.value;
        const negative = negativePrompt.value.trim();
        const imageUrl = buildImageUrl(prompt, ratio.width, ratio.height, seed, model, negative);

        seedInput.value = seed;
        setLoading(true);
        closeMobileSidebar();

        try {
          await preloadImage(imageUrl);

          state.currentImageUrl = imageUrl;
          state.currentPrompt = prompt;

          resultImage.src = imageUrl;
          resultImage.alt = `AI generated image: ${prompt}`;
          resultImage.classList.remove("hidden");
          resultActions.classList.remove("hidden");
          resultActions.classList.add("flex");
          resultBadge.textContent = `${ratio.label} • ${model.toUpperCase()} • Seed ${seed}`;
          resultBadge.classList.remove("hidden");

          const item = {
            id: `${Date.now()}-${seed}`,
            url: imageUrl,
            prompt,
            ratio: state.ratio,
            style: styleSelect.value,
            model,
            seed,
            negative,
            createdAt: new Date().toISOString()
          };

          state.currentHistoryId = item.id;
          state.history.unshift(item);
          state.history = state.history.slice(0, 24);
          saveHistory();
          renderHistory();
          showToast("Your image is ready.", "success");
        } catch (error) {
          console.error(error);
          resetCanvas();
          showToast("Image generation failed. Check your internet connection and try again.", "error");
        } finally {
          setLoading(false);
        }
      }

      function preloadImage(url) {
        return new Promise((resolve, reject) => {
          const image = new Image();
          image.onload = () => resolve(url);
          image.onerror = () => reject(new Error("Image API request failed."));
          image.src = url;
        });
      }

      generateButton.addEventListener("click", generateImage);

      // ---------- History ----------
      function renderHistory() {
        historyGrid.innerHTML = "";
        emptyHistory.classList.toggle("hidden", state.history.length > 0);

        state.history.forEach(item => {
          const button = document.createElement("button");
          button.className = `history-item group relative aspect-square overflow-hidden rounded-xl border border-white/10 bg-slate-900 ${item.id === state.currentHistoryId ? "active" : ""}`;
          button.title = item.prompt;
          button.innerHTML = `
            <img src="${item.url}" alt="${escapeHTML(item.prompt)}" class="h-full w-full object-cover transition duration-500 group-hover:scale-110" loading="lazy" />
            <span class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 transition group-hover:opacity-100"></span>
            <span class="absolute inset-x-2 bottom-2 truncate text-left text-[9px] font-semibold text-white opacity-0 transition group-hover:opacity-100">${escapeHTML(item.prompt)}</span>
          `;

          button.addEventListener("click", () => restoreHistoryItem(item));
          historyGrid.appendChild(button);
        });
      }

      function restoreHistoryItem(item) {
        state.currentImageUrl = item.url;
        state.currentPrompt = item.prompt;
        state.currentHistoryId = item.id;

        promptInput.value = item.prompt;
        styleSelect.value = item.style || "Cinematic";
        modelSelect.value = item.model || "flux";
        seedInput.value = item.seed ?? "";
        negativePrompt.value = item.negative || "";
        setRatio(item.ratio || "square");
        resizePromptInput();

        placeholderState.classList.add("hidden");
        loadingState.classList.add("hidden");
        resultImage.src = item.url;
        resultImage.alt = `AI generated image: ${item.prompt}`;
        resultImage.classList.remove("hidden");
        resultActions.classList.remove("hidden");
        resultActions.classList.add("flex");
        resultBadge.textContent = `${ratioMap[item.ratio || "square"].label} • ${(item.model || "flux").toUpperCase()} • Seed ${item.seed}`;
        resultBadge.classList.remove("hidden");

        renderHistory();
        closeMobileSidebar();
      }

      clearHistoryButton.addEventListener("click", () => {
        if (!state.history.length) {
          showToast("History is already empty.", "info");
          return;
        }

        const confirmed = window.confirm("Clear all saved image history from this browser?");
        if (!confirmed) return;

        state.history = [];
        saveHistory();
        renderHistory();
        resetCanvas();
        showToast("Generation history cleared.", "success");
      });

      // ---------- Download / Share ----------
      downloadButton.addEventListener("click", async () => {
        if (!state.currentImageUrl) return;

        downloadButton.disabled = true;
        downloadButton.innerHTML = '<i class="ph ph-spinner animate-spin"></i> Preparing';

        try {
          const response = await fetch(state.currentImageUrl);
          if (!response.ok) throw new Error("Download request failed.");

          const blob = await response.blob();
          const objectUrl = URL.createObjectURL(blob);
          const anchor = document.createElement("a");
          anchor.href = objectUrl;
          anchor.download = `prismai-${Date.now()}.png`;
          document.body.appendChild(anchor);
          anchor.click();
          anchor.remove();
          URL.revokeObjectURL(objectUrl);
          showToast("Image download started.", "success");
        } catch (error) {
          console.warn(error);
          window.open(state.currentImageUrl, "_blank", "noopener,noreferrer");
          showToast("The image opened in a new tab. Save it from there.", "info");
        } finally {
          downloadButton.disabled = false;
          downloadButton.innerHTML = '<i class="ph ph-download-simple"></i> Download';
        }
      });

      shareButton.addEventListener("click", async () => {
        if (!state.currentImageUrl) return;

        const shareData = {
          title: "PrismAI Creation",
          text: state.currentPrompt,
          url: state.currentImageUrl
        };

        try {
          if (navigator.share) {
            await navigator.share(shareData);
          } else {
            await navigator.clipboard.writeText(`${state.currentPrompt}\n${state.currentImageUrl}`);
            showToast("Image link and prompt copied to clipboard.", "success");
          }
        } catch (error) {
          if (error.name !== "AbortError") {
            try {
              await navigator.clipboard.writeText(state.currentImageUrl);
              showToast("Image link copied to clipboard.", "success");
            } catch {
              showToast("Sharing is not supported in this browser.", "error");
            }
          }
        }
      });

      clearCanvasButton.addEventListener("click", resetCanvas);

      // ---------- Scroll reveal ----------
      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      document.querySelectorAll(".reveal").forEach(element => observer.observe(element));

      // Card cursor glow
      document.querySelectorAll(".feature-card, .blog-card").forEach(card => {
        card.addEventListener("mousemove", event => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty("--x", `${event.clientX - rect.left}px`);
          card.style.setProperty("--y", `${event.clientY - rect.top}px`);
        });
      });

      // Newsletter demo
      document.getElementById("newsletterForm").addEventListener("submit", event => {
        event.preventDefault();
        event.currentTarget.reset();
        showToast("Thanks! You are on the creative newsletter list.", "success");
      });

      // Prevent demo links from jumping
      document.querySelectorAll('a[href="#"]').forEach(link => {
        link.addEventListener("click", event => event.preventDefault());
      });

      // Escape key behavior
      document.addEventListener("keydown", event => {
        if (event.key === "Escape") {
          if (!sidebarOverlay.classList.contains("hidden")) {
            closeMobileSidebar();
          } else if (!appInterface.classList.contains("hidden")) {
            closeApp();
          }
        }
      });

      // Initial render
      setRatio("square");
      renderHistory();
      resizePromptInput();
    })();
  </script>
</body>
</html>
