  <style>
    :root {
      color-scheme: dark;
      --bg: #020617;
      --surface: #0f172a;
      --primary: #6366f1;
      --secondary: #d946ef;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 15% 0%, rgba(99, 102, 241, 0.16), transparent 28%),
        radial-gradient(circle at 90% 18%, rgba(217, 70, 239, 0.12), transparent 26%),
        #020617;
      color: #f8fafc;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    ::selection {
      background: rgba(99, 102, 241, 0.5);
      color: #fff;
    }

    ::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }

    ::-webkit-scrollbar-track {
      background: #020617;
    }

    ::-webkit-scrollbar-thumb {
      background: #29324a;
      border: 2px solid #020617;
      border-radius: 999px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #3d4864;
    }

    .glass {
      background: rgba(15, 23, 42, 0.62);
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .glass-dark {
      background: rgba(2, 6, 23, 0.76);
      border: 1px solid rgba(255, 255, 255, 0.09);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .gradient-text {
      background: linear-gradient(100deg, #c7d2fe 0%, #818cf8 32%, #e879f9 67%, #f0abfc 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .gradient-border {
      position: relative;
      isolation: isolate;
    }

    .gradient-border::before {
      content: "";
      position: absolute;
      z-index: -1;
      inset: -1px;
      border-radius: inherit;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.7), rgba(217, 70, 239, 0.45), transparent 70%);
      opacity: 0.8;
    }

    .noise::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.025;
      z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.8'/%3E%3C/svg%3E");
    }

    .hero-grid {
      background-image:
        linear-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
      background-size: 54px 54px;
      mask-image: linear-gradient(to bottom, black, transparent 85%);
    }

    .blob {
      filter: blur(60px);
      opacity: 0.32;
      animation: blobFloat 9s ease-in-out infinite alternate;
    }

    .blob:nth-child(2) {
      animation-delay: -3s;
    }

    @keyframes blobFloat {
      from { transform: translate3d(-12px, -8px, 0) scale(1); }
      to   { transform: translate3d(18px, 22px, 0) scale(1.12); }
    }

    .float-3d {
      animation: float3d 6s ease-in-out infinite;
      transform-style: preserve-3d;
      will-change: transform;
    }

    .float-3d.delay-1 { animation-delay: -1.8s; }
    .float-3d.delay-2 { animation-delay: -3.4s; }
    .float-3d.delay-3 { animation-delay: -4.7s; }

    @keyframes float3d {
      0%, 100% { transform: translateY(0) rotateX(0deg) rotateY(0deg); }
      50% { transform: translateY(-18px) rotateX(9deg) rotateY(-9deg); }
    }

    .image-marquee {
      display: flex;
      width: max-content;
      animation: marquee 30s linear infinite;
    }

    .image-marquee:hover {
      animation-play-state: paused;
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.75s ease, transform 0.75s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .feature-card::after,
    .blog-card::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
      background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(99, 102, 241, 0.16), transparent 35%);
      opacity: 0;
      transition: opacity 0.35s ease;
    }

    .feature-card:hover::after,
    .blog-card:hover::after {
      opacity: 1;
    }

    .gallery-card img,
    .blog-card img {
      transition: transform 0.7s cubic-bezier(.2,.8,.2,1), filter 0.5s ease;
    }

    .gallery-card:hover img,
    .blog-card:hover img {
      transform: scale(1.055);
    }

    .gallery-card .prompt-overlay {
      transform: translateY(18px);
      opacity: 0;
      transition: 0.35s ease;
    }

    .gallery-card:hover .prompt-overlay {
      transform: translateY(0);
      opacity: 1;
    }

    .button-shine {
      position: relative;
      overflow: hidden;
    }

    .button-shine::after {
      content: "";
      position: absolute;
      top: -120%;
      left: -30%;
      width: 25%;
      height: 340%;
      transform: rotate(24deg);
      background: linear-gradient(to right, transparent, rgba(255,255,255,.32), transparent);
      transition: left 0.65s ease;
    }

    .button-shine:hover::after {
      left: 115%;
    }

    .app-fade-in {
      animation: appFade 0.45s ease both;
    }

    @keyframes appFade {
      from { opacity: 0; transform: scale(0.99); }
      to { opacity: 1; transform: scale(1); }
    }

    .spinner {
      width: 58px;
      height: 58px;
      border: 4px solid rgba(255,255,255,0.1);
      border-top-color: #818cf8;
      border-right-color: #d946ef;
      border-radius: 50%;
      animation: spin 0.85s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .result-image {
      animation: imageReveal 0.6s cubic-bezier(.2,.8,.2,1) both;
    }

    @keyframes imageReveal {
      from { opacity: 0; transform: scale(0.965); filter: blur(10px); }
      to { opacity: 1; transform: scale(1); filter: blur(0); }
    }

    .ratio-btn.active {
      border-color: rgba(129, 140, 248, 0.95);
      background: rgba(99, 102, 241, 0.18);
      color: #c7d2fe;
      box-shadow: 0 0 24px rgba(99, 102, 241, 0.15);
    }

    .history-item.active {
      outline: 2px solid #818cf8;
      outline-offset: 2px;
    }

    .sidebar-scroll {
      scrollbar-width: thin;
      scrollbar-color: #334155 transparent;
    }

    .canvas-checker {
      background-image:
        linear-gradient(45deg, rgba(255,255,255,.025) 25%, transparent 25%),
        linear-gradient(-45deg, rgba(255,255,255,.025) 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, rgba(255,255,255,.025) 75%),
        linear-gradient(-45deg, transparent 75%, rgba(255,255,255,.025) 75%);
      background-size: 28px 28px;
      background-position: 0 0, 0 14px, 14px -14px, -14px 0;
    }

    .toast {
      animation: toastIn 0.35s ease both;
    }

    @keyframes toastIn {
      from { opacity: 0; transform: translateY(12px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @media (max-width: 767px) {
      .image-marquee {
        animation-duration: 22s;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        scroll-behavior: auto !important;
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }
    }
  </style>
</head>

